<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.student.StudentCoursesController"
            prefWidth="1200.0" prefHeight="750.0"
            style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);
                     -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="72">
                <padding>
                    <Insets left="24" right="24"/>
                </padding>

                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 22;">
                    <Label text="📚" style="-fx-font-size: 20px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="My Courses"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label fx:id="subtitleLabel" text="Your enrolled modules"
                           style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-size: 10px;"/>
                </VBox>

                <VBox alignment="CENTER_LEFT" spacing="4" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <padding>
                        <Insets left="8" right="8"/>
                    </padding>
                    <Label text="Your courses &amp; grades"
                           style="-fx-text-fill: rgba(255,255,255,0.72); -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <Label fx:id="headerCoursesLabel" text=""
                           wrapText="true"
                           maxWidth="680"
                           style="-fx-text-fill: rgba(255,255,255,0.98); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets left="10" right="20"/>
                </padding>

                <StackPane>
                    <Circle radius="18" style="-fx-fill: white;"/>
                    <Label fx:id="profileInitial" text="S"
                           style="-fx-text-fill: #3f7fc2; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="studentNameLabel" text="Student Name"
                           style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label fx:id="studentIdLabel" text="Reg No: —"
                           style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;"/>
                </VBox>

                <Button text="← Back" onAction="#goBack"
                        style="-fx-background-color: rgba(255,255,255,0.18);
                               -fx-text-fill: white;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-border-color: rgba(255,255,255,0.22);
                               -fx-border-radius: 8;
                               -fx-border-width: 1;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="18" style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="28" bottom="28" left="34" right="34"/>
                </padding>

                <VBox spacing="8"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets top="18" bottom="18" left="22" right="22"/>
                    </padding>

                    <Label text="🗓  Timetable-style course list"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label fx:id="infoLabel" text="Loading your courses…"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
                </VBox>

                <GridPane fx:id="timetableGrid"
                          hgap="14" vgap="14"
                          style="-fx-background-color: transparent;"/>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #fbfdff; -fx-border-color: #dfeaf6; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="9" bottom="9" left="28" right="28"/>
            </padding>
            <Circle radius="4" style="-fx-fill: #4cba52;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>

