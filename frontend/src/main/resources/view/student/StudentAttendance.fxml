<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.student.StudentAttendanceController"
            prefWidth="1200.0" prefHeight="750.0"
            style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);
                     -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="72">
                <padding><Insets left="24" right="24"/></padding>

                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 22;">
                    <Label text="✅" style="-fx-font-size: 20px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="Attendance"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label fx:id="subtitleLabel" text="My attendance only"
                           style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10">
                <padding><Insets left="10" right="20"/></padding>

                <StackPane>
                    <Circle radius="18" style="-fx-fill: white;"/>
                    <Label fx:id="profileInitial" text="S"
                           style="-fx-text-fill: #3f7fc2; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="studentNameLabel" text="Student Name"
                           style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label fx:id="studentIdLabel" text="Reg No: —"
                           style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;"/>
                </VBox>

                <Button text="← Back" onAction="#goBack"
                        style="-fx-background-color: rgba(255,255,255,0.18);
                               -fx-text-fill: white;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-border-color: rgba(255,255,255,0.22);
                               -fx-border-radius: 8;
                               -fx-border-width: 1;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="18" style="-fx-background-color: transparent;">
                <padding><Insets top="28" bottom="28" left="34" right="34"/></padding>

                <VBox spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>

                    <Label text="📊  Overall Summary"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Separator style="-fx-background-color: #e7eef7;"/>

                    <FlowPane hgap="14" vgap="14">
                        <VBox spacing="6" prefWidth="200"
                              style="-fx-background-color: #f5f9ff; -fx-background-radius: 14; -fx-border-color: #d7e7f8; -fx-border-radius: 14; -fx-border-width: 1;">
                            <padding><Insets top="14" bottom="14" left="16" right="16"/></padding>
                            <Label text="Attendance %" style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Label fx:id="attendancePctLabel" text="—%" style="-fx-text-fill: #1a3a52; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                            <Label fx:id="scenarioLabel" text="" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                        </VBox>

                        <VBox spacing="6" prefWidth="200"
                              style="-fx-background-color: #f5f9ff; -fx-background-radius: 14; -fx-border-color: #d7e7f8; -fx-border-radius: 14; -fx-border-width: 1;">
                            <padding><Insets top="14" bottom="14" left="16" right="16"/></padding>
                            <Label text="Present" style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Label fx:id="presentCountLabel" text="—" style="-fx-text-fill: #1a3a52; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                            <Label text="Expected sessions (assumed)" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                        </VBox>

                        <VBox spacing="6" prefWidth="200"
                              style="-fx-background-color: #f5f9ff; -fx-background-radius: 14; -fx-border-color: #d7e7f8; -fx-border-radius: 14; -fx-border-width: 1;">
                            <padding><Insets top="14" bottom="14" left="16" right="16"/></padding>
                            <Label text="Absent" style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                            <Label fx:id="absentCountLabel" text="—" style="-fx-text-fill: #1a3a52; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                            <Label text="Based on expected sessions" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                        </VBox>
                    </FlowPane>

                    <Label fx:id="statusLabel" text="Loading…" style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
                </VBox>

                <VBox spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding><Insets top="22" bottom="22" left="24" right="24"/></padding>

                    <Label text="🧾  Recent Attendance Records"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Separator style="-fx-background-color: #e7eef7;"/>

                    <HBox spacing="0"
                          style="-fx-background-color: #f5f9ff; -fx-background-radius: 10;">
                        <padding><Insets top="9" bottom="9" left="12" right="12"/></padding>
                        <Label text="Course ID" prefWidth="160"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label text="Date" prefWidth="140"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label text="Type" prefWidth="110"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label text="Status" prefWidth="110"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label text="Hours" prefWidth="90"
                               style="-fx-text-fill: #4c8fce; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    </HBox>

                    <VBox fx:id="recordsContainer" spacing="6"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>

