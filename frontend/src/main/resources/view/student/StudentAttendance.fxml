<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.student.StudentAttendanceController"
            prefWidth="1000.0" prefHeight="700.0"
            style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);">

    <!-- ══════════ HEADER ══════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);
                     -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="72">
                <padding><Insets left="24" right="24"/></padding>

                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 22;">
                    <Label text="📋" style="-fx-font-size: 22px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="My Attendance"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Subject-wise attendance summary"
                           style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="10" alignment="CENTER">
                <padding><Insets left="10" right="24"/></padding>
                <Button text="← Back to Dashboard" onAction="#backToDashboard"
                        style="-fx-background-color: rgba(255,255,255,0.22);
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-border-color: rgba(255,255,255,0.3);
                               -fx-border-radius: 8;
                               -fx-border-width: 1;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ══════════ BODY ══════════ -->
    <center>
        <VBox spacing="20">
            <padding><Insets top="30" bottom="30" left="40" right="40"/></padding>

            <!-- Summary Bar -->
            <HBox alignment="CENTER_LEFT" spacing="30"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-border-color: #d7e7f8;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.10), 10, 0, 0, 3);">
                <padding><Insets top="15" bottom="15" left="24" right="24"/></padding>

                <!-- Overall % -->
                <VBox alignment="CENTER" spacing="2">
                    <Label text="OVERALL" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <Label fx:id="overallPctLabel" text="—%"
                           style="-fx-text-fill: #3f7fc2; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Attendance" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>

                <!-- divider -->
                <Region style="-fx-background-color: #e0ecf8;" prefWidth="1" prefHeight="50"/>

                <!-- Courses -->
                <VBox alignment="CENTER" spacing="2">
                    <Label text="COURSES" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <Label fx:id="courseCountLabel" text="0"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Registered" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>

                <!-- divider -->
                <Region style="-fx-background-color: #e0ecf8;" prefWidth="1" prefHeight="50"/>

                <!-- Total Present -->
                <VBox alignment="CENTER" spacing="2">
                    <Label text="PRESENT" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <Label fx:id="totalPresentLabel" text="0"
                           style="-fx-text-fill: #4cba52; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Sessions" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>

                <!-- divider -->
                <Region style="-fx-background-color: #e0ecf8;" prefWidth="1" prefHeight="50"/>

                <!-- Total Absent -->
                <VBox alignment="CENTER" spacing="2">
                    <Label text="ABSENT" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    <Label fx:id="totalAbsentLabel" text="0"
                           style="-fx-text-fill: #e85d5d; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Sessions" style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Eligibility badge -->
                <Label fx:id="eligibilityLabel" text=""
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14 6 14;"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="attendanceTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-radius: 8;
                              -fx-border-radius: 8;
                              -fx-border-color: #d7e7f8;
                              -fx-border-width: 1;
                              -fx-font-family: 'Segoe UI', Arial, sans-serif;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colCourseId" text="Course ID" prefWidth="110">
                        <cellValueFactory><PropertyValueFactory property="courseId"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colCourseName" text="Course Name" prefWidth="260">
                        <cellValueFactory><PropertyValueFactory property="courseName"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colTotal" text="Total Sessions" prefWidth="120">
                        <cellValueFactory><PropertyValueFactory property="totalSessions"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colPresent" text="Present" prefWidth="90">
                        <cellValueFactory><PropertyValueFactory property="presentCount"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colAbsent" text="Absent" prefWidth="90">
                        <cellValueFactory><PropertyValueFactory property="absentCount"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colHours" text="Hours Attended" prefWidth="120">
                        <cellValueFactory><PropertyValueFactory property="totalHoursAttended"/></cellValueFactory>
                    </TableColumn>
                    <TableColumn fx:id="colPct" text="Attendance %" prefWidth="120">
                        <cellValueFactory><PropertyValueFactory property="attendancePercentage"/></cellValueFactory>
                    </TableColumn>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
