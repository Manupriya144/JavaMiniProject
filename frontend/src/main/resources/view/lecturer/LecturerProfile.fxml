<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.lecturer.LecturerProfileController"
            prefWidth="900"
            prefHeight="650"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #5b9fd9;">
            <padding>
                <Insets top="18" right="28" bottom="18" left="28"/>
            </padding>

            <VBox>
                <Label text="Lecturer Profile"
                       style="-fx-text-fill: white; -fx-font-size: 23px; -fx-font-weight: bold;"/>
                <Label text="Update designation and profile picture"
                       style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 12px;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Back"
                    onAction="#goBack"
                    style="-fx-background-color: white; -fx-text-fill: #3f7fc2; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18">
            <padding>
                <Insets top="35" right="80" bottom="35" left="80"/>
            </padding>

            <HBox spacing="24" alignment="CENTER_LEFT">
                <StackPane prefWidth="80" prefHeight="80">
                    <Circle radius="38" style="-fx-fill: #5b9fd9;"/>
                    <ImageView fx:id="profileImage"
                               fitWidth="76"
                               fitHeight="76"
                               preserveRatio="true"
                               visible="false"/>
                    <Label fx:id="profileInitial"
                           text="L"
                           style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                </StackPane>

                <VBox spacing="4">
                    <Label fx:id="usernameLabel"
                           text="Lecturer"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label fx:id="emailLabel"
                           text="email"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <Separator/>

            <GridPane hgap="18" vgap="14">
                <columnConstraints>
                    <ColumnConstraints prefWidth="170"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="User ID" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="userIdField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Username" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Email" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Contact Number" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="contactNumberField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Specialization" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="specializationField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <Label text="Designation" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="designationField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <Label text="Profile Picture" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <HBox spacing="10" GridPane.rowIndex="6" GridPane.columnIndex="1">
                    <TextField fx:id="profilePictureField" HBox.hgrow="ALWAYS"/>
                    <Button text="Browse" onAction="#browseProfilePicture"/>
                </HBox>
            </GridPane>

            <Button fx:id="saveBtn"
                    text="Save Changes"
                    onAction="#saveProfile"
                    prefHeight="42"
                    style="-fx-background-color: #4cba52; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>

            <Label fx:id="statusLabel" text=""/>
        </VBox>
    </center>
</BorderPane>