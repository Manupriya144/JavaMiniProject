<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.lecturer.LecturerProfileController"
            prefWidth="1180"
            prefHeight="650"
            style="-fx-background-color: #f8fbff;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 0 0 1 0;">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="64">
                <padding>
                    <Insets left="28" right="28"/>
                </padding>

                <Label text="🎓" style="-fx-font-size: 28px;"/>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="👨‍🏫 Lecturer Profile"
                   style="-fx-text-fill: #5b9fd9; -fx-font-size: 13px; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets left="16" right="24"/>
                </padding>

                <StackPane prefWidth="36" prefHeight="36">
                    <ImageView fx:id="headerAvatarImage"
                               fitWidth="36"
                               fitHeight="36"
                               preserveRatio="false"
                               visible="false"/>

                    <Label fx:id="headerAvatarInitial"
                           text="L"
                           style="-fx-background-color: #5b9fd9;
                                  -fx-text-fill: white;
                                  -fx-font-weight: bold;
                                  -fx-font-size: 14px;
                                  -fx-alignment: center;
                                  -fx-background-radius: 18;
                                  -fx-min-width: 36;
                                  -fx-min-height: 36;
                                  -fx-max-width: 36;
                                  -fx-max-height: 36;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="usernameLabel"
                           text="Lecturer"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label text="Lecturer"
                           style="-fx-text-fill: #8fa3b8; -fx-font-size: 9px;"/>
                </VBox>

                <Button text="← Back"
                        onAction="#goBack"
                        style="-fx-background-color: #e8eef5; -fx-text-fill: #1a3a52; -fx-font-size: 11px; -fx-background-radius: 6; -fx-font-weight: bold;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="22">
            <padding>
                <Insets top="26" right="32" bottom="26" left="32"/>
            </padding>

            <VBox spacing="5">
                <Label text="Lecturer Profile"
                       style="-fx-text-fill: #1a3a52; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                <Label text="View your account details and update designation or profile picture."
                       style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
            </VBox>

            <HBox spacing="22" VBox.vgrow="ALWAYS">

                <VBox spacing="0"
                      prefWidth="330"
                      style="-fx-background-color: #fafbff; -fx-background-radius: 14; -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1.5;">

                    <HBox alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: #f5f9ff; -fx-background-radius: 14 14 0 0;">
                        <padding>
                            <Insets top="16" right="20" bottom="16" left="20"/>
                        </padding>

                        <Label text="🧾" style="-fx-font-size: 17px;"/>

                        <VBox spacing="1">
                            <Label text="Profile Summary"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                            <Label text="Current lecturer information"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="16" alignment="CENTER">
                        <padding>
                            <Insets top="30" right="22" bottom="30" left="22"/>
                        </padding>

                        <StackPane prefWidth="84" prefHeight="84">
                            <ImageView fx:id="profileImage"
                                       fitWidth="84"
                                       fitHeight="84"
                                       preserveRatio="false"
                                       visible="false"/>

                            <Label fx:id="profileInitial"
                                   text="L"
                                   style="-fx-background-color: #5b9fd9;
                                          -fx-text-fill: white;
                                          -fx-font-size: 28px;
                                          -fx-font-weight: bold;
                                          -fx-alignment: center;
                                          -fx-background-radius: 42;
                                          -fx-min-width: 84;
                                          -fx-min-height: 84;
                                          -fx-max-width: 84;
                                          -fx-max-height: 84;"/>
                        </StackPane>

                        <VBox spacing="5" alignment="CENTER">
                            <Label fx:id="emailLabel"
                                   text="email"
                                   wrapText="true"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
                        </VBox>

                        <Separator/>

                        <Label text="Only designation and profile picture can be updated."
                               wrapText="true"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 12px;"/>
                    </VBox>
                </VBox>

                <VBox spacing="0"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #fafbff; -fx-background-radius: 14; -fx-border-color: #d4e4f7; -fx-border-radius: 14; -fx-border-width: 1.5;">

                    <HBox alignment="CENTER_LEFT" spacing="10"
                          style="-fx-background-color: #f5f9ff; -fx-background-radius: 14 14 0 0;">
                        <padding>
                            <Insets top="16" right="20" bottom="16" left="20"/>
                        </padding>

                        <Label text="✏️" style="-fx-font-size: 17px;"/>

                        <VBox spacing="1">
                            <Label text="Profile Details"
                                   style="-fx-text-fill: #1a3a52; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                            <Label text="Update editable lecturer profile fields"
                                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="20">
                        <padding>
                            <Insets top="28" right="34" bottom="30" left="34"/>
                        </padding>

                        <GridPane hgap="18" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="170"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="User ID" style="-fx-text-fill: #1a3a52; -fx-font-weight: bold;"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="userIdField" prefHeight="38"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Username" style="-fx-text-fill: #1a3a52; -fx-font-weight: bold;"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="usernameField" prefHeight="38"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Email" style="-fx-text-fill: #1a3a52; -fx-font-weight: bold;"
                                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="emailField" prefHeight="38"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Contact Number" style="-fx-text-fill: #1a3a52; -fx-font-weight: bold;"
                                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="contactNumberField" prefHeight="38"
                                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Specialization" style="-fx-text-fill: #1a3a52; -fx-font-weight: bold;"
                                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="specializationField" prefHeight="38"
                                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                            <Label text="Designation" style="-fx-text-fill: #1a3a52; -fx-font-weight: bold;"
                                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <TextField fx:id="designationField" prefHeight="38"
                                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                            <Label text="Profile Picture" style="-fx-text-fill: #1a3a52; -fx-font-weight: bold;"
                                   GridPane.rowIndex="6" GridPane.columnIndex="0"/>

                            <HBox spacing="10" GridPane.rowIndex="6" GridPane.columnIndex="1">
                                <TextField fx:id="profilePictureField"
                                           prefHeight="38"
                                           HBox.hgrow="ALWAYS"/>
                                <Button text="Browse"
                                        onAction="#browseProfilePicture"
                                        prefHeight="38"
                                        style="-fx-background-color: #5b9fd9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                            </HBox>
                        </GridPane>

                        <HBox alignment="CENTER_RIGHT" spacing="12">
                            <Button fx:id="saveBtn"
                                    text="Save Changes"
                                    onAction="#saveProfile"
                                    prefHeight="42"
                                    prefWidth="180"
                                    style="-fx-background-color: #4cba52; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #ffffff; -fx-border-color: #e8eef5; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="10" bottom="10" left="28" right="28"/>
            </padding>

            <Label text="●" style="-fx-text-fill: #4cba52;"/>
            <Label fx:id="statusLabel"
                   text="Ready"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Lecturer Profile"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>