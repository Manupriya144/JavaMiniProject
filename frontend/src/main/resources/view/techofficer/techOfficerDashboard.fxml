<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.tech_officer.TechOfficerDashboardController"
            prefWidth="1200.0" prefHeight="750.0"
            style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2);
                     -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="72">
                <padding>
                    <Insets left="24" right="24"/>
                </padding>

                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 22;">
                    <Label text="🎓" style="-fx-font-size: 22px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Technical Officer Panel"
                           style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox spacing="6" alignment="CENTER">
                <padding>
                    <Insets left="16" right="16"/>
                </padding>

                <Button text="Dashboard"
                        style="-fx-background-color: rgba(255,255,255,0.22);
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;"/>

                <Button text="Attendance" onAction="#openAttendance"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;"/>

                <Button text="Timetables" onAction="#openTimetables"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;"/>

                <Button text="Notices" onAction="#openNotices"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: white;
                               -fx-font-size: 13px;
                               -fx-background-radius: 10;
                               -fx-padding: 8 18 8 18;
                               -fx-cursor: hand;"/>
            </HBox>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets left="10" right="20"/>
                </padding>

                <StackPane>
                    <Circle radius="18" style="-fx-fill: white;"/>

                    <ImageView fx:id="dashboardProfileImage"
                               fitWidth="36"
                               fitHeight="36"
                               preserveRatio="false"
                               visible="false"/>

                    <Label fx:id="dashboardProfileInitial"
                           text="T"
                           style="-fx-text-fill: #3f7fc2; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="techNameLabel" text="Tech Officer"
                           style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label text="Technical Officer"
                           style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;"/>
                </VBox>

                <Button text="My Profile" onAction="#openProfile"
                        style="-fx-background-color: rgba(255,255,255,0.18);
                               -fx-text-fill: white;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-border-color: rgba(255,255,255,0.22);
                               -fx-border-radius: 8;
                               -fx-border-width: 1;"/>

                <Button text="Logout" onAction="#logout"
                        style="-fx-background-color: white;
                               -fx-text-fill: #e85d5d;
                               -fx-font-size: 12px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="26" style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="28" bottom="28" left="34" right="34"/>
                </padding>

                <HBox spacing="18" alignment="CENTER_LEFT"
                      style="-fx-background-color: linear-gradient(to right, #ffffff, #f3f8ff);
                             -fx-background-radius: 18;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 18;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 16, 0, 0, 5);">
                    <padding>
                        <Insets top="22" bottom="22" left="24" right="24"/>
                    </padding>

                    <StackPane prefWidth="58" prefHeight="58"
                               style="-fx-background-color: linear-gradient(to bottom right, #8e5fd2, #b083ea);
                                      -fx-background-radius: 29;">

                        <ImageView fx:id="welcomeProfileImage"
                                   fitWidth="58"
                                   fitHeight="58"
                                   preserveRatio="false"
                                   visible="false"/>

                        <Label fx:id="welcomeProfileInitial"
                               text="🛠"
                               style="-fx-font-size: 22px;"/>
                    </StackPane>

                    <VBox spacing="5">
                        <Label fx:id="welcomeLabel" text="Welcome, Tech Officer 👋"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 27px; -fx-font-weight: bold;"/>
                        <Label fx:id="dateLabel" text="Thursday, March 13, 2026  •  Technical Officer Panel"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <FlowPane hgap="18" vgap="18" prefWrapLength="1100">

                    <VBox spacing="8" prefWidth="220" prefHeight="122"
                          style="-fx-background-color: linear-gradient(to bottom right, #faf5ff, #fdfaff);
                                 -fx-background-radius: 16;
                                 -fx-border-color: #ead8ff;
                                 -fx-border-radius: 16;
                                 -fx-border-width: 1;
                                 -fx-effect: dropshadow(three-pass-box, rgba(163,101,229,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets top="20" bottom="20" left="22" right="22"/>
                        </padding>
                        <Label text="👤  Total Students"
                               style="-fx-text-fill: #8e5fd2; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalStudentsLabel" text="20"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Active undergrads"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="220" prefHeight="122"
                          style="-fx-background-color: linear-gradient(to bottom right, #eef8ff, #f8fbff);
                                 -fx-background-radius: 16;
                                 -fx-border-color: #d8e7f7;
                                 -fx-border-radius: 16;
                                 -fx-border-width: 1;
                                 -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.16), 14, 0, 0, 5);">
                        <padding>
                            <Insets top="20" bottom="20" left="22" right="22"/>
                        </padding>
                        <Label text="📋  Attendance Sessions"
                               style="-fx-text-fill: #468ed0; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="attendanceSessionsLabel" text="15"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Per subject"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="220" prefHeight="122"
                          style="-fx-background-color: linear-gradient(to bottom right, #fff8ef, #fffdf8);
                                 -fx-background-radius: 16;
                                 -fx-border-color: #ffe0aa;
                                 -fx-border-radius: 16;
                                 -fx-border-width: 1;
                                 -fx-effect: dropshadow(three-pass-box, rgba(240,170,79,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets top="20" bottom="20" left="22" right="22"/>
                        </padding>
                        <Label text="⚠️  Pending Approvals"
                               style="-fx-text-fill: #d98928; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="pendingApprovalsLabel" text="—"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Pending requests"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
                    </VBox>

                </FlowPane>

                <VBox spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets top="22" bottom="22" left="24" right="24"/>
                    </padding>

                    <Label text="Quick Actions"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Separator style="-fx-background-color: #e7eef7;"/>

                    <FlowPane hgap="12" vgap="12">
                        <Button text="✅  Mark Attendance" onAction="#openMarkAttendance" prefHeight="42" prefWidth="190"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white;
                                       -fx-font-size: 13px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;"/>

                        <Button text="📋  View Attendance" onAction="#openAttendance" prefHeight="42" prefWidth="190"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white;
                                       -fx-font-size: 13px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;"/>

                        <Button text="📊  Advanced Attendance View" onAction="#openAdvancedAttendanceView" prefHeight="42" prefWidth="220"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white;
                                       -fx-font-size: 13px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;"/>

                        <Button text="📅  Timetable" onAction="#openTimetables" prefHeight="42" prefWidth="190"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white;
                                       -fx-font-size: 13px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-cursor: hand;"/>
                    </FlowPane>
                </VBox>

                <VBox spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-border-color: #d7e7f8;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets top="22" bottom="22" left="24" right="24"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="📊  Attendance Overview (Batch)"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Full Report →" onAction="#openAttendance"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #4c8fce;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <Separator style="-fx-background-color: #e7eef7;"/>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Batch" style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;"/>

                        <TextField fx:id="batchEligibilityField" promptText="e.g. 2023" prefWidth="140"
                                   style="-fx-background-color: #ffffff;
                                          -fx-text-fill: #1a3a52;
                                          -fx-prompt-text-fill: #a8b8ca;
                                          -fx-border-color: #d4e4f7;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;"/>

                        <Label text="View" style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;"/>

                        <ComboBox fx:id="viewTypeEligibilityCombo" prefWidth="150"
                                  style="-fx-background-color: #ffffff;
                                         -fx-border-color: #d4e4f7;
                                         -fx-border-radius: 8;
                                         -fx-background-radius: 8;"/>

                        <Button text="Refresh" onAction="#refreshAttendanceEligibilityReport" prefHeight="34"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce);
                                       -fx-text-fill: white;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;"/>
                    </HBox>

                    <HBox spacing="24" alignment="CENTER_LEFT">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="●" style="-fx-text-fill: #4cba52; -fx-font-size: 14px;"/>
                            <Label text="Above 80%" style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;"/>
                        </HBox>

                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="●" style="-fx-text-fill: #f2c94c; -fx-font-size: 14px;"/>
                            <Label text="Exactly 80%" style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;"/>
                        </HBox>

                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="●" style="-fx-text-fill: #e85d5d; -fx-font-size: 14px;"/>
                            <Label text="Below 80%" style="-fx-text-fill: #7f93a8; -fx-font-size: 12px;"/>
                        </HBox>

                    </HBox>

                    <VBox fx:id="attendanceSummaryContainer" spacing="8"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #fbfdff; -fx-border-color: #dfeaf6; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="9" bottom="9" left="28" right="28"/>
            </padding>

            <Circle radius="4" style="-fx-fill: #4cba52;"/>

            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="statusBarTime" text="13 March 2026"
                   style="-fx-text-fill: #8fa3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>