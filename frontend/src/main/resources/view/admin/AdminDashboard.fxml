<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.frontend.controller.admin.AdminDashboardController"
            prefWidth="1200.0" prefHeight="750.0"
            style="-fx-background-color: linear-gradient(to bottom right, #eef6ff, #fdfcff);">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: linear-gradient(to right, #5b9fd9, #3f7fc2); -fx-effect: dropshadow(three-pass-box, rgba(63,127,194,0.25), 14, 0, 0, 3);">

            <padding>
                <Insets top="0" right="0" bottom="0" left="0"/>
            </padding>

            <!-- Logo area -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" prefHeight="72.0">
                <padding>
                    <Insets top="0" right="24" bottom="0" left="24"/>
                </padding>

                <StackPane prefWidth="44" prefHeight="44"
                           style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 22;">
                    <Label text="🎓" style="-fx-font-size: 22px;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="FoT Portal"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Faculty of Technology Management System"
                           style="-fx-text-fill: rgba(255,255,255,0.80); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Navigation -->
            <HBox alignment="CENTER" spacing="6">
                <padding>
                    <Insets top="0" right="16" bottom="0" left="16"/>
                </padding>

                <Button fx:id="navDashboard" text="Dashboard"
                        style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>

                <Button fx:id="navUsers" text="Users" onAction="#openUsers"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>

                <Button fx:id="navCourses" text="Courses" onAction="#openCourses"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>

                <Button fx:id="navNotices" text="Notices" onAction="#openNotices"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>

                <Button fx:id="navTimetables" text="Timetables" onAction="#openTimetables"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 8 18 8 18; -fx-cursor: hand;"/>
            </HBox>

            <!-- Right side -->
            <HBox alignment="CENTER" spacing="12">
                <padding>
                    <Insets top="0" right="22" bottom="0" left="10"/>
                </padding>

                <StackPane>
                    <Circle radius="19" style="-fx-fill: white;"/>
                    <Label text="A" style="-fx-text-fill: #3f7fc2; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </StackPane>

                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label fx:id="adminNameLabel" text="Administrator"
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    <Label text="Admin"
                           style="-fx-text-fill: rgba(255,255,255,0.78); -fx-font-size: 10px;"/>
                </VBox>

                <Button text="Logout" onAction="#logout"
                        style="-fx-background-color: white; -fx-text-fill: #e85d5d; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="-fx-background-color: transparent; -fx-background: transparent;">

            <VBox spacing="26"
                  style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="28" right="34" bottom="28" left="34"/>
                </padding>

                <!-- Welcome banner -->
                <HBox spacing="18" alignment="CENTER_LEFT"
                      style="-fx-background-color: linear-gradient(to right, #ffffff, #f3f8ff); -fx-background-radius: 18; -fx-border-color: #d7e7f8; -fx-border-radius: 18; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 16, 0, 0, 5);">
                    <padding>
                        <Insets top="22" right="24" bottom="22" left="24"/>
                    </padding>

                    <StackPane prefWidth="58" prefHeight="58"
                               style="-fx-background-color: linear-gradient(to bottom right, #5b9fd9, #7cb7ea); -fx-background-radius: 29;">
                        <Label text="👋" style="-fx-font-size: 24px;"/>
                    </StackPane>

                    <VBox spacing="5">
                        <Label fx:id="welcomeLabel"
                               text="Welcome back, Administrator 👋"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 27px; -fx-font-weight: bold;"/>
                        <Label fx:id="dateLabel"
                               text="Thursday, March 13, 2026  •  Admin Control Panel"
                               style="-fx-text-fill: #8fa3b8; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <!-- Stats -->
                <FlowPane hgap="18" vgap="18" prefWrapLength="1100">

                    <VBox spacing="8" prefWidth="205" prefHeight="122"
                          style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #d8e7f7; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.16), 14, 0, 0, 5);">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="👥  Total Users"
                               style="-fx-text-fill: #7b91a8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalUsersLabel" text="30"
                               style="-fx-text-fill: #234766; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Across all roles"
                               style="-fx-text-fill: #a3b5c7; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="205" prefHeight="122"
                          style="-fx-background-color: linear-gradient(to bottom right, #effcf4, #f7fff9); -fx-background-radius: 16; -fx-border-color: #cfead7; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(109,186,130,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="🎓  Undergraduates"
                               style="-fx-text-fill: #2f9b50; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalStudentsLabel" text="20"
                               style="-fx-text-fill: #1f6d38; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Active students"
                               style="-fx-text-fill: #6eaa7d; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="205" prefHeight="122"
                          style="-fx-background-color: linear-gradient(to bottom right, #fff9ef, #fffdf8); -fx-background-radius: 16; -fx-border-color: #ffe0aa; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(240,170,79,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="📚  Lecturers"
                               style="-fx-text-fill: #da7a09; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalLecturersLabel" text="5"
                               style="-fx-text-fill: #b65c05; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Faculty members"
                               style="-fx-text-fill: #d4a15f; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="205" prefHeight="122"
                          style="-fx-background-color: linear-gradient(to bottom right, #faf5ff, #fdfaff); -fx-background-radius: 16; -fx-border-color: #ead8ff; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(163,101,229,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="🔧  Tech Officers"
                               style="-fx-text-fill: #8d3ee8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalTechLabel" text="4"
                               style="-fx-text-fill: #6a24b8; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="Department staff"
                               style="-fx-text-fill: #b08dda; -fx-font-size: 11px;"/>
                    </VBox>

                    <VBox spacing="8" prefWidth="205" prefHeight="122"
                          style="-fx-background-color: linear-gradient(to bottom right, #eef8ff, #f9fcff); -fx-background-radius: 16; -fx-border-color: #cce8fb; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                        <padding>
                            <Insets top="20" right="22" bottom="20" left="22"/>
                        </padding>
                        <Label text="📋  Courses"
                               style="-fx-text-fill: #1976b9; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Label fx:id="totalCoursesLabel" text="8"
                               style="-fx-text-fill: #0f507c; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label text="This semester"
                               style="-fx-text-fill: #6a9cc5; -fx-font-size: 11px;"/>
                    </VBox>

                </FlowPane>

                <!-- Quick actions -->
                <VBox spacing="14"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #d7e7f8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets top="22" right="24" bottom="22" left="24"/>
                    </padding>

                    <Label text="Quick Actions"
                           style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Separator style="-fx-background-color: #e7eef7;"/>

                    <FlowPane hgap="12" vgap="12">
                        <Button text="➕  Add User" onAction="#openAddUser" prefHeight="44" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="📖  Add Course" onAction="#openAddCourses" prefHeight="44" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="🔗  Assign Course" onAction="#openAssignCourse" prefHeight="44" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="📢  Post Notice" onAction="#openAddNotices" prefHeight="44" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>

                        <Button text="📅  Add Timetable" onAction="#openTimeAddTimeTables" prefHeight="44" prefWidth="180"
                                style="-fx-background-color: linear-gradient(to right, #5b9fd9, #4c8fce); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    </FlowPane>
                </VBox>

                <!-- Recent notices -->
                <VBox spacing="14"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-border-color: #d7e7f8; -fx-border-radius: 16; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(91,159,217,0.14), 14, 0, 0, 5);">
                    <padding>
                        <Insets top="22" right="24" bottom="22" left="24"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="📢  Recent Notices"
                               style="-fx-text-fill: #1a3a52; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="View All →" onAction="#openNotices"
                                style="-fx-background-color: transparent; -fx-text-fill: #4c8fce; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>

                    <Separator style="-fx-background-color: #e7eef7;"/>

                    <VBox fx:id="noticesContainer" spacing="10"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- BOTTOM STATUS BAR -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #fbfdff; -fx-border-color: #dfeaf6; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets top="9" right="24" bottom="9" left="24"/>
            </padding>

            <Label text="●" style="-fx-text-fill: #35b45a; -fx-font-size: 10px;"/>
            <Label text="System Online  •  Faculty of Technology Management System  •  v1.0"
                   style="-fx-text-fill: #7f93a8; -fx-font-size: 11px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="statusBarTime" text="13 March 2026"
                   style="-fx-text-fill: #7f93a8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>